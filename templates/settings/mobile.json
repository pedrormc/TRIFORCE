{
  "env": {
    "CLAUDE_ENVIRONMENT": "mobile",
    "CLAUDE_MACHINE": "termux-android"
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(npm list:*)",
      "Bash(ssh -T:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(gh:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(docker run:*)",
      "Bash(docker stop:*)",
      "Bash(docker rm:*)",
      "Bash(docker exec:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",
      "Read(**/.env*)",
      "Read(**/.pem)",
      "Read(**/.key)",
      "Read(**/credentials*)",
      "Read(**/secret*)"
    ]
  }
}
